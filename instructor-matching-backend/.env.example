# Required for agent-core A/B review and Gemini embeddings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Copy the privately shared instructor DB to data/private/ after cloning.
INSTRUCTOR_DATABASE_URL=sqlite+aiosqlite:///./data/private/내부_강사_정보.db
AGENT_CORE_PATH=../agent_core
AGENT_REVIEW_TOP_K=10

# Runtime data (excluded from Git).
VECTOR_STORE_PATH=data/vector-store/rag.sqlite3
AGENT_RUN_STORAGE_DIR=data/agent-runs
AGENT_BATCH_RUN_STORAGE_DIR=data/agent-batch-runs

# Set a unique production value outside version control.
SECRET_KEY=
